# Google Identity Services (Firebase Auth Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase web app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# MariaDB (same DB as Gurotopia). For Vercel, MYSQL_HOST must be your VPS public IP.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=gurotopia
MYSQL_PASSWORD=
MYSQL_DATABASE=gurotopia
# MYSQL_SSL=0
